# Render demo profile for alice-skill
# Use this only for a stateless hosted demo.
# To enable a real LLM later, switch LLM_PROVIDER to openai-compatible
# and provide either LLM_API_URL + LLM_API_KEY, or OPENROUTER_API_KEY.

PORT=10000
LLM_PROVIDER=mock
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=openai/gpt-5.4-mini

OPENCLAW_TRANSPORT=mock-rpc
OPENCLAW_BINARY=openclaw
OPENCLAW_RPC_WORKER_SCRIPT=
OPENCLAW_TEST_TIMEOUT_MS=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.4-mini
